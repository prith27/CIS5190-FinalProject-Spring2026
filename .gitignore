# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Secrets — never commit
*.pem
.env
.env.*

# OS / IDE
.DS_Store
.idea/
.vscode/
.cursor/
.cursor

# Checkpoints (large) — track via SUBMISSION_LOG checksums; use Git LFS if you must version them
*.pt
*.pth
artifacts/*.pt
artifacts/*.pth

# Keep artifacts dir
!artifacts/.gitkeep

# Jupyter
.ipynb_checkpoints/

# Local dataset trees (images + metadata); document HF Dataset URL in docs instead of committing large files
data/*
!data/.gitkeep

# Large course assets (keep locally — bloated remote / flaky pushes)
# Baseline notebook embeds Colab outputs (~10MB+).
project-resources/Img2GPS/Release_baseline_model.ipynb
# Reference photos for Img2GPS (metadata.csv stays tracked).
project-resources/Img2GPS/reference/*.jpg
project-resources/Img2GPS/reference/*.jpeg
project-resources/Img2GPS/reference/*.png
