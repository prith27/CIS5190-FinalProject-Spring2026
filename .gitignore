*.pth

# Training outputs under ./artifacts/ — do not push (keep folder via .gitkeep)
/artifacts/*
!/artifacts/.gitkeep

# Jupyter
.ipynb_checkpoints/

# Local dataset trees (images + metadata); document HF Dataset URL in docs instead of committing large files
data/*
!data/.gitkeep

